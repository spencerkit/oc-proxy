{
  "name": "ai-open-router",
  "version": "0.2.1",
  "description": "Desktop OpenAI <-> Anthropic compatible protocol router",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "check": "npm run lint && npm run typecheck && npm run test:ci",
    "ci": "npm run check && npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "cargo tauri dev",
    "tauri:dev": "cargo tauri dev",
    "tauri:collect": "bash ./scripts/collect-tauri-artifacts.sh",
    "tauri:build": "CARGO_TARGET_DIR=\"$PWD/dist/target\" cargo tauri build && npm run tauri:collect",
    "tauri:build:win": "CARGO_TARGET_DIR=\"$PWD/dist/target\" cargo tauri build --target x86_64-pc-windows-gnu && npm run tauri:collect",
    "test": "node --require ./scripts/register-ts.js --test",
    "test:ci": "node --require ./scripts/register-ts.js --test --test-timeout=30000",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "i18next": "^23.10.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.0",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.0"
  }
}
