{
  "name": "ai-open-router",
  "version": "0.3.1",
  "description": "Desktop OpenAI <-> Anthropic compatible protocol router",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "check": "npm run lint && npm run typecheck && npm run test:ci",
    "ci": "npm run check && npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "cargo tauri dev",
    "start:tauri": "cargo tauri dev -- --bin ai-open-router-tauri",
    "start:bin": "cargo run --bin ai-open-router --manifest-path src-tauri/Cargo.toml",
    "tauri:dev": "cargo tauri dev",
    "tauri:dev:fail": "AOR_DEBUG_FORCE_LOAD_FAILED_PAGE=1 cargo tauri dev",
    "tauri:collect": "bash ./scripts/collect-tauri-artifacts.sh",
    "tauri:build": "CARGO_TARGET_DIR=\"$PWD/dist/target\" cargo tauri build && npm run tauri:collect",
    "tauri:build:win": "CARGO_TARGET_DIR=\"$PWD/dist/target\" cargo tauri build --target x86_64-pc-windows-gnu && npm run tauri:collect",
    "test": "npm run test:rust && npm run test:unit:ts",
    "test:ci": "npm run test:rust && npm run test:unit:ts",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:unit:ts": "rm -rf .tmp/unit-tests && tsc -p tsconfig.unit.json && node --test .tmp/unit-tests/tests/unit/*.test.js",
    "mock:upstream": "node ./scripts/mock-upstream.js --host 127.0.0.1 --port 19001",
    "screenshots:mock": "node ./scripts/capture-screenshots.js",
    "bench:proxy": "node ./scripts/benchmark-proxy.js --config ./scripts/benchmark.example.json",
    "bench:proxy:mock": "node ./scripts/run-benchmark-with-mock.js --config ./scripts/benchmark.example.json --output out/bench-report.json",
    "e2e:headless": "node ./scripts/e2e-headless.js",
    "version:check": "node ./scripts/check-version-sync.js",
    "release:plan": "bash ./scripts/release-runner.sh --dry-run --bump auto",
    "release:prepare": "bash ./scripts/release-runner.sh --bump auto",
    "prepare": "husky install",
    "e2e:tauri": "wdio run e2e-tests/wdio.conf.cjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@relax-state/core": "0.0.10",
    "@relax-state/react": "0.0.10",
    "echarts": "^6.0.0",
    "i18next": "^26.0.1",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.1",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
