{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/renderer/*": ["src/renderer/*"],
      "@/types": ["src/renderer/types/index"],
      "@/types/*": ["src/renderer/types/*"],
      "@/components": ["src/renderer/components/index"],
      "@/components/*": ["src/renderer/components/*"],
      "@/hooks": ["src/renderer/hooks/index"],
      "@/hooks/*": ["src/renderer/hooks/*"],
      "@/store": ["src/renderer/store/index"],
      "@/store/*": ["src/renderer/store/*"],
      "@/utils": ["src/renderer/utils/index"],
      "@/utils/*": ["src/renderer/utils/*"],
      "@/i18n": ["src/renderer/i18n/index"],
      "@/i18n/*": ["src/renderer/i18n/*"],
      "@/pages": ["src/renderer/pages/index"],
      "@/pages/*": ["src/renderer/pages/*"],
      "@/contexts": ["src/renderer/contexts/index"],
      "@/contexts/*": ["src/renderer/contexts/*"],
      "@relax-state/core": ["src/types/relax-state-core.d.ts"],
      "@relax-state/react": ["src/types/relax-state-react.d.ts"],
      "@relax-state/store": ["src/types/relax-state-store.d.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
