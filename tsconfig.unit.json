{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/renderer/*": ["src/renderer/*"],
      "@/types": ["src/renderer/types/index"],
      "@/types/*": ["src/renderer/types/*"],
      "@/components": ["src/renderer/components/index"],
      "@/components/*": ["src/renderer/components/*"],
      "@/hooks": ["src/renderer/hooks/index"],
      "@/hooks/*": ["src/renderer/hooks/*"],
      "@/store": ["src/renderer/store/index"],
      "@/store/*": ["src/renderer/store/*"],
      "@/utils": ["src/renderer/utils/index"],
      "@/utils/*": ["src/renderer/utils/*"],
      "@/i18n": ["src/renderer/i18n/index"],
      "@/i18n/*": ["src/renderer/i18n/*"],
      "@/pages": ["src/renderer/pages/index"],
      "@/pages/*": ["src/renderer/pages/*"],
      "@/contexts": ["src/renderer/contexts/index"],
      "@/contexts/*": ["src/renderer/contexts/*"],
      "@relax-state/store": ["src/types/relax-state-store.d.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "rootDir": ".",
    "outDir": ".tmp/unit-tests"
  },
  "include": [
    "tests/unit/**/*.ts",
    "src/renderer/vite-env.d.ts",
    "src/renderer/types/index.ts",
    "src/renderer/types/config.ts",
    "src/renderer/types/proxy.ts",
    "src/renderer/pages/AgentEditPage/AgentEditPage.tsx",
    "src/renderer/pages/AgentEditPage/agentEditPageSections.ts",
    "src/renderer/pages/AgentEditPage/AgentEditContent.tsx",
    "src/renderer/pages/AgentEditPage/AgentSourceTabs.tsx",
    "src/renderer/pages/AgentEditPage/OpenClawEditorForm.tsx",
    "src/renderer/pages/GroupEditPage/GroupEditPage.tsx",
    "src/renderer/pages/RuleFormPage/RuleFormPage.tsx",
    "src/renderer/pages/RuleFormPage/ProviderImportCard.tsx",
    "src/renderer/pages/ServicePage/ProviderList.tsx",
    "src/renderer/pages/LogsPage/LogsPage.tsx",
    "src/renderer/utils/agentSourceFormat.ts",
    "src/renderer/utils/groupFailover.ts",
    "src/renderer/utils/importMode.ts",
    "src/renderer/utils/providerImport.ts",
    "src/renderer/utils/providerTesting.ts",
    "src/renderer/utils/providerWebsite.ts",
    "src/renderer/utils/serverAddress.ts",
    "src/renderer/hooks/useLogs.ts"
  ]
}
